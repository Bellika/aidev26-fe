# API Configuration
# For local development, use localhost
# For production (Railway), use your backend API URL
VITE_API_BASE_URL=http://localhost:8000

# Cypress Testing Configuration (not needed for production)
CYPRESS_BASE_URL=http://localhost:5173
CYPRESS_TEST_PASSWORD=testpass123

# Railway Deployment Notes:
# 1. In Railway dashboard, add environment variable:
#    VITE_API_BASE_URL=https://your-backend-api.railway.app
# 2. Railway will automatically set PORT variable
# 3. No need to set CYPRESS variables in production
